# Copie este arquivo para .env e preencha os valores
# O arquivo .env nunca deve ser commitado no Git

# String de conexão do MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/yugioh?retryWrites=true&w=majority

# Segredo para assinar os tokens JWT — use uma string longa e aleatória em produção
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria-em-producao
